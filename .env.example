# SGM Drivers — Environment Variables
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# Flask secret key — change to a long random string in production
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# Database URL
# SQLite (local/development):
DATABASE_URL=sqlite:///sgm_drivers.db
# PostgreSQL (Heroku/Render production):
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Flask environment
FLASK_ENV=production
FLASK_DEBUG=0

# Optional: host and port for local run
HOST=0.0.0.0
PORT=5000
